pipeline {
    agent any

    tools {
        jdk   'jdk 21'
        maven 'Maven 3.8.7'
    }

    environment {
        IMAGE = "neeraj91/${JOB_NAME}:v1.${BUILD_ID}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // Combined: Build + Test + Coverage + Sonar in ONE mvn command
        stage('Build, Test & SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                        mvn clean verify sonar:sonar \
                        -B \
                        -f demo/pom.xml
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build & Tag') {
            steps {
                sh "docker build -t ${IMAGE} ."
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin
                        docker push ${IMAGE}
                    """
                }
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    docker stop ${JOB_NAME} || true
                    docker rm   ${JOB_NAME} || true
                    docker run -d --name ${JOB_NAME} -p 9090:8080 ${IMAGE}
                """
            }
        }
    }

    post {
        always { cleanWs() }
        success { echo "✅ Pipeline completed! Image: ${IMAGE}" }
        failure { echo "❌ Pipeline failed. Check logs above." }
    }
}